# Stock watchlist (trading bot) — core high-sentiment stocks + commodity/defensive ETFs
WATCHLIST=AAPL,MSFT,NVDA,GOOGL,TSLA,AMZN,COIN,META,AMD,PLTR,GLD,SLV,GDX,USO,SPY,QQQ

# ETF symbols (comma-separated) — sentiment filter is relaxed for these
ETF_SYMBOLS=GLD,SLV,GDX,USO,SPY,QQQ,IAU,CPER

# Risk settings — tighter for ETFs (lower volatility), handled per-symbol in strategy
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.25
RISK_PER_TRADE=0.02
LONG_HORIZON_CASH_BUFFER_PCT=0.05
LONG_HORIZON_MAX_RISK_PER_TRADE=0.025
MIN_SENTIMENT_TO_BUY=0
TRADE_COOLDOWN_MINUTES=240
BUY_THRESHOLD_PCT=0.008
SELL_THRESHOLD_PCT=0.010
MIN_TREND_STRENGTH_PCT=0.006

# Retraining — reduce overhead while keeping models fresh
AUTO_RETRAIN_ENABLED=true
AUTO_RETRAIN_INTERVAL_HOURS=24
RETRAIN_LOOKBACK_PERIOD=1y

# Research-assisted force-buy tuning (slightly more permissive for learning)
TECH_RESEARCH_FORCE_BUY_MIN_PROBABILITY=0.90
TECH_RESEARCH_FORCE_BUY_MIN_IMPACT_SCORE=7.5
TECH_RESEARCH_FORCE_BUY_MIN_EVIDENCE_COUNT=4
TECH_RESEARCH_FORCE_BUY_MAX_SIGNAL_AGE_HOURS=24
TECH_RESEARCH_FORCE_BUY_MAX_CANDIDATES=10
TECH_RESEARCH_FORCE_BUY_RISK_MULTIPLIER=0.20

# Long-term architecture controls
FUNDAMENTALS_GATE_ENABLED=true
FUNDAMENTALS_MIN_SCORE=0.65
FUNDAMENTALS_MIN_MARKET_CAP_BILLION=10
FUNDAMENTALS_MAX_DEBT_TO_EQUITY=200
FUNDAMENTALS_REQUIRE_POSITIVE_FCF=true
LONG_TERM_MIN_HOLD_HOURS=168
LONG_TERM_MAX_PORTFOLIO_DRAWDOWN_PCT=0.25
LONG_TERM_MAX_TOTAL_EXPOSURE_PCT=0.85
LONG_TERM_MAX_SYMBOL_EXPOSURE_PCT=0.12

# Growth-momentum path: buy strong trending stocks even without Capitol Trades political signal
# (political data can be up to 45 days stale — this ensures trending growth stocks aren't missed)
GROWTH_MOMENTUM_BUY_ENABLED=true
GROWTH_MOMENTUM_MIN_TREND_MULTIPLIER=1.5
GROWTH_MOMENTUM_MIN_RETURN_MULTIPLIER=2.0

# Autonomous mode: allow cautious/normal operation even before enough closes accumulate
AUTONOMOUS_MIN_CLOSED_TRADES=0

# Global macro data enrichment (all sourced free via yfinance)
# VIX > 30 = extreme fear — blocks new entries on individual stocks
# News sentiment scored from yfinance headlines per symbol (cached 30 min)
# Sector momentum checked via XLK/XLE/XLF/SPY ETFs (cached 30 min)

# Event learner: maps news topic exposure to realized forward returns over time
EVENT_LEARNER_ALPHA=0.15
EVENT_MAX_EDGE_ADJUSTMENT_PCT=0.8
EVENT_LEARNER_LAGS=1,3,6
EVENT_BOOTSTRAP_ENABLED=true
EVENT_BOOTSTRAP_YEARS=50
EVENT_BOOTSTRAP_INTERVAL=1mo
EVENT_BOOTSTRAP_MIN_OBSERVATIONS=120
EVENT_INFLUENCE_REPORT_ENABLED=true
EVENT_INFLUENCE_REPORT_INTERVAL_MINUTES=1440
EVENT_INFLUENCE_REPORT_TOPICS=8
EVENT_INFLUENCE_REPORT_SYMBOLS=6

# --- Crypto bot: tuned settings ---
CRYPTO_WATCHLIST=BTC/USD,ETH/USD,SOL/USD,AVAX/USD,DOGE/USD,XRP/USD,LINK/USD,LTC/USD
CRYPTO_PAPER_ONLY=true
CRYPTO_RISK_PER_TRADE=0.02          # 2% per trade — aligned with stock bot for consistency across long-horizon portfolio
CRYPTO_MAX_POSITIONS=4              # 4 concurrent (was 5) — avoids over-diversification
CRYPTO_STOP_LOSS_PCT=0.05           # 5% fixed stop (was 4%) — gives room for normal crypto noise
CRYPTO_TAKE_PROFIT_PCT=0.15         # 15% target (was 12%) — better R:R on high-volatility assets
CRYPTO_RSI_BUY_THRESHOLD=45         # slightly more permissive rebound trigger for better entry frequency
CRYPTO_RSI_SELL_THRESHOLD=70        # tighter exit (was 72) — lock in profits earlier
CRYPTO_MIN_TREND_STRENGTH_PCT=0.0010 # 0.10% trend required — slightly easier entries without removing trend confirmation
CRYPTO_LOOP_INTERVAL_SECONDS=120
CRYPTO_MIN_NOTIONAL_PER_TRADE=25
CRYPTO_ATR_STOP_MULTIPLIER=2.0      # wider ATR trailing stop (was 1.5) — survive normal crypto swings
CRYPTO_MIN_VOLUME_PERCENTILE=40     # require top 60% volume (was 25%) — trade only in liquid conditions
# MACD: fast periods aligned with EMA windows for signal confluence
CRYPTO_MACD_FAST=8
CRYPTO_MACD_SLOW=21
CRYPTO_MACD_SIGNAL=5
# EMA windows aligned with MACD periods — fast/slow crossover confirms MACD crossover
CRYPTO_FAST_EMA_WINDOW=8            # aligned with MACD fast (was 10)
CRYPTO_SLOW_EMA_WINDOW=21           # aligned with MACD slow (was 30)
# Longer lookback = better indicator calibration (more RSI/EMA history)
CRYPTO_LOOKBACK_PERIOD=180d         # 6 months (was 90d) — double the training history
CRYPTO_RSI_PERIOD=14
CRYPTO_RESEARCH_HARD_BLOCK_SCORE=-55
CRYPTO_RESEARCH_SOFT_BLOCK_SCORE=-45
CRYPTO_RESEARCH_ENTRY_GUARD_SCORE=-45
