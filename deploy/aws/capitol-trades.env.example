# Copy to: /etc/capitol-trades/capitol-trades.env
# Keep this file out of git. Recommended mode: 600.

# Shared runtime flags
RESTART_DELAY=10

# Dashboard token (used by supervise_dashboard.sh)
DASHBOARD_VIEW_TOKEN=change-me

# Example AWS region for any SDK usage
AWS_REGION=us-east-1

# Add your existing bot/API env vars below.
# Example placeholders:
# ALPACA_API_KEY=...
# ALPACA_SECRET_KEY=...
# OPENAI_API_KEY=...
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1
