# Capitol Trades source
CAPITOL_TRADES_API_URL=https://api.capitoltrades.com
CAPITOL_TRADES_MAX_PAGES=5

# Alpaca paper trading credentials
ALPACA_API_KEY=your-alpaca-key
ALPACA_API_SECRET=your-alpaca-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional strategy tuning
WATCHLIST=AAPL,MSFT,NVDA,GOOGL,TSLA,AMZN
TRAINING_SYMBOLS=AAPL,MSFT,NVDA,GOOGL,TSLA,AMZN
BUY_THRESHOLD_PCT=0.002
SELL_THRESHOLD_PCT=0.002
MIN_SENTIMENT_TO_BUY=1
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.06

# Adaptive experience learner
ADAPTIVE_POLICY_ENABLED=true
ADAPTIVE_POLICY_LEARNING_RATE=0.08
ADAPTIVE_POLICY_DECAY=0.999
ADAPTIVE_POLICY_MAX_ADJUSTMENT_PCT=0.6

# Internet research search provider
SEARCH_PROVIDER=serpapi
SEARCH_ENGINE=google
SEARCH_API_KEY=your-serpapi-key
