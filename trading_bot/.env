# --- Alerting / Observability ---
# Set ALERTS_ENABLED=true to activate. Fill in Telegram or Webhook credentials below.
ALERTS_ENABLED=false
ALERT_MIN_INTERVAL_SECONDS=900

# Telegram: create a bot via @BotFather, get your chat ID via @userinfobot
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Slack / Discord / custom: paste your incoming webhook URL here
ALERT_WEBHOOK_URL=

# Which events fire alerts (true/false)
ALERT_KILL_SWITCH_ENABLED=true
ALERT_SOURCE_DEGRADED_ENABLED=true

# Fire one test alert on startup to verify delivery (set false after confirming)
ALERT_SELF_TEST_ON_START=false

# How many consecutive per-symbol errors before escalating (default 3)
ALERT_SYMBOL_ERROR_THRESHOLD=3
ALERT_SYMBOL_ERROR_COOLDOWN_SECONDS=1800

# How old (seconds) the political feed must be before a stale-data critical alert fires (3h default)
ALERT_SOURCE_STALE_SECONDS=10800

# --- Walk-forward validation ---
# Runs weekly after retrain. On OOS fail, drops to cautious mode (risk_mult=0.50)
# until the next pass. Disable if you want raw backtest-only mode.
WALK_FORWARD_ENABLED=true
WALK_FORWARD_INTERVAL_HOURS=168
WALK_FORWARD_TRAIN_MONTHS=6
WALK_FORWARD_TEST_MONTHS=1
WALK_FORWARD_MIN_FOLDS=3
WALK_FORWARD_MAX_FOLDS=6
# Thresholds that trigger "fail" verdict — tweak if too strict/loose
WALK_FORWARD_FAIL_PROFIT_FACTOR=0.90
WALK_FORWARD_FAIL_SHARPE=-0.20
WALK_FORWARD_FAIL_MAX_DD_PCT=30.0
# Risk multiplier applied when OOS fails
WALK_FORWARD_CAUTIOUS_RISK_MULTIPLIER=0.50